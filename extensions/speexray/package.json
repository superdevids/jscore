{
  "name": "speexray",
  "displayName": "speexray",
  "description": "Dependency health scanner — detect bloat, security issues, and suggest replacements",
  "version": "0.2.0",
  "publisher": "speexjs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/superdevids/speexjs"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "speexjs",
    "framework",
    "scaffolding",
    "dependencies",
    "migrations",
    "routes"
  ],
  "activationEvents": [
    "onLanguage:json",
    "onLanguage:typescript",
    "onCommand:speexray.scan",
    "onCommand:speexjs.createController",
    "onCommand:speexjs.createModel",
    "onCommand:speexjs.showRoutes",
    "onCommand:speexjs.runMigrations",
    "workspaceContains:**/speexjs.config.*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "speexray.scan",
        "title": "speexray: Scan Dependencies"
      },
      {
        "command": "speexray.scanWorkspace",
        "title": "speexray: Scan Workspace Dependencies"
      },
      {
        "command": "speexray.applyReplacement",
        "title": "speexray: Apply Replacement",
        "icon": "$(lightbulb)"
      },
      {
        "command": "speexjs.createController",
        "title": "SpeexJS: New Controller"
      },
      {
        "command": "speexjs.createModel",
        "title": "SpeexJS: New Model"
      },
      {
        "command": "speexjs.createMiddleware",
        "title": "SpeexJS: New Middleware"
      },
      {
        "command": "speexjs.createRoute",
        "title": "SpeexJS: New Route"
      },
      {
        "command": "speexjs.showRoutes",
        "title": "SpeexJS: Show All Routes"
      },
      {
        "command": "speexjs.runMigrations",
        "title": "SpeexJS: Migration Runner"
      }
    ],
    "configuration": {
      "title": "speexray",
      "properties": {
        "speexray.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable speexray diagnostics"
        },
        "speexray.showReplacementHints": {
          "type": "boolean",
          "default": true,
          "description": "Show replacement suggestions as hints"
        },
        "speexray.scanOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Auto-scan when opening package.json"
        }
      }
    },
    "menus": {
      "editor/title/context": [
        {
          "when": "resourceFilename == 'package.json'",
          "command": "speexray.scan",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "when": "explorerResourceIsFolder && resourceFilename =~ /controllers/",
          "command": "speexjs.createController",
          "group": "speexjs@1"
        },
        {
          "when": "explorerResourceIsFolder && resourceFilename =~ /models/",
          "command": "speexjs.createModel",
          "group": "speexjs@1"
        },
        {
          "when": "explorerResourceIsFolder && resourceFilename =~ /middleware/",
          "command": "speexjs.createMiddleware",
          "group": "speexjs@1"
        },
        {
          "when": "explorerResourceIsFolder && resourceFilename =~ /routes/",
          "command": "speexjs.createRoute",
          "group": "speexjs@1"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "speexrayResults",
          "name": "speexray Results"
        },
        {
          "id": "speexjsRoutes",
          "name": "SpeexJS Routes"
        },
        {
          "id": "speexjsMigrations",
          "name": "SpeexJS Migrations"
        }
      ]
    },
    "languages": [
      {
        "id": "speexjs-template",
        "aliases": [
          "SpeexJS Template",
          "speexjs-template"
        ],
        "extensions": [
          ".speex.html",
          ".speex.view",
          ".view.html"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "speexjs-template",
        "scopeName": "source.speexjs-template",
        "path": "./syntaxes/speexjs-template.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.0"
  }
}
